# Google AI Studio (Gemini) API key.
GEMINI_API_KEY=

# Chat model used by the agent (LiteLLM route).
CHAT_MODEL=gemini/gemini-flash-lite-latest

# Embedding model used for semantic search.
EMBED_MODEL=gemini/gemini-embedding-2

# Backend base URL used by the Streamlit client and the demo script.
BACKEND_URL=http://127.0.0.1:8000
